# MyAIAssistant runtime configuration
# Copy this file to .env for local development, or let the installer create it for packaged builds.

# Cloud providers
HUGGINGFACE_TOKEN=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/hf-inference/v1
OPENAI_API_KEY=
MODEL_PROVIDER=ollama
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local Ollama defaults
CHAT_MODEL_LOCAL=qwen2.5:0.5b
EMBEDDING_MODEL_LOCAL=nomic-embed-text
OLLAMA_BASE_URL=http://127.0.0.1:11434
START_OLLAMA_WITH_LAUNCHER=true

# Launcher networking
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5000
AUTO_OPEN_BROWSER=true

# Backend runtime
DEBUG=false
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_documents
DOCUMENTS_DIR=./documents
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
DATABASE_URL=
